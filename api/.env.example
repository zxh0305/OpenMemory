# ------ Required Configurations ------
USER=user
CREATE_DEFAULT_USER=false
DATABASE_URL=sqlite:///./openmemory.db

# --- Qdrant Configuration ---
QDRANT_HOST=mem0_store
QDRANT_PORT=6333

# --- LLM Model Configuration (以硅基流动为例) ---
OPENAI_API_KEY=sk-xx
OPENAI_PROVIDER=openai
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=deepseek-ai/DeepSeek-V3

# --- Embedding Model Configuration ---
OPENAI_EMBEDDING_MODEL_API_KEY=sk-xx
OPENAI_EMBEDDING_MODEL_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
OPENAI_EMBEDDING_MODEL_DIMS=1024

# --- Categorization Configuration ---
CATEGORIZATION_OPENAI_BASE_URL=https://api.siliconflow.cn/v1
CATEGORIZATION_OPENAI_API_KEY=sk-xx
CATEGORIZATION_OPENAI_MODEL=deepseek-ai/DeepSeek-V3
CATEGORIZATION_OPENAI_PROVIDER=openai_structured

# ------ Memory Decay Configuration ------
# Enable or disable memory decay feature
MEMORY_DECAY_ENABLED=true

# Half-life period in days (how fast memories decay)
# Default: 30 days (memories lose 50% strength after 30 days without access)
MEMORY_DECAY_HALF_LIFE_DAYS=30

# Auto-archive threshold (0.0 - 1.0)
# Memories with decay score below this threshold will be automatically archived
# Default: 0.1 (archive memories with less than 10% strength)
MEMORY_DECAY_AUTO_ARCHIVE_THRESHOLD=0.1

# Schedule for decay update (hour of day, 0-23)
# Default: 2 (runs at 2:00 AM daily)
MEMORY_DECAY_UPDATE_HOUR=2

# Schedule for decay update (minute of hour, 0-59)
# Default: 0
MEMORY_DECAY_UPDATE_MINUTE=0